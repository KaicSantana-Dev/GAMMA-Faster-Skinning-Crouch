# Normalize text files to LF (avoids CRLF doubling in editors)
*.script text eol=lf
*.ltx text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.ini text eol=lf
*.mod_id text eol=lf
*.sh text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.editorconfig text eol=lf
githooks/pre-commit text eol=lf

*.ppe binary
*.png binary
*.dds binary
*.pdn binary
*.mp4 binary
*.omf binary
*.ogg binary
